8)create view clientes_ciudades as SELECT c.*,ci.nombre as ciudad from clientes c join ciudades ci on c.localidad = ci.id;

9)create view ubicacion as SELECT c.nombre,p.nombre as provincia from ciudades c join provincias p on c.provincia = p.id

10)create view ultima_compra as SELECT c.nombre,c.apellido,max(co.fecha) ultima_fecha from clientes c join compras co on c.id = co.cliente group by c.id,c.nombre,c.apellido
